# NewsForNerds Configuration
# Copy to .env and fill in values. All values shown are defaults unless noted.
# Environment variables override .env file values.

# --- Server ---
# LISTEN_ADDR=:8000
# DB_PATH=db.sqlite3
# LOG_FILE=logs/newsfornerds.log
# LOG_LEVEL=info  # debug, info, warn, error
# CANONICAL_DOMAIN=          # if set, redirects all other hosts to this domain

# --- Google OAuth (required for login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Feed Settings ---
# FEED_REFRESH_INTERVAL=1     # minutes between refresh cycles
# FEED_STALE_MINUTES=5        # minutes before a feed is stale
# FEED_ERROR_BACKOFF=30       # minutes before retrying errored feeds
# FEED_MAX_ITEMS=50           # max items stored per feed
# FEED_MAX_PER_CYCLE=5        # max feeds refreshed per cycle
# FEED_FETCH_TIMEOUT=30       # seconds for HTTP requests

# --- Session & Cookies ---
# SESSION_DURATION_DAYS=30    # session cookie lifetime
# VISITOR_DURATION_DAYS=365   # visitor cookie lifetime

# --- Default Colors ---
# DEFAULT_BG_COLOR=#1a1a2e         # page background
# DEFAULT_WIDGET_BG=#16213e        # widget background
# DEFAULT_WIDGET_TEXT=#ffffff       # widget text
# DEFAULT_WIDGET_HEADER=#0f3460    # widget header

# --- Cleanup ---
# VISITED_LINK_MAX_DAYS=30   # days to keep visited link records
